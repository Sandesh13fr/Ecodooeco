<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Emission Factor Views -->
        <record id="view_ecodoo_emission_factor_form" model="ir.ui.view">
            <field name="name">ecodoo.emission.factor.form</field>
            <field name="model">ecodoo.emission.factor</field>
            <field name="arch" type="xml">
                <form string="Emission Factor">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,approved,archived"/>
                        <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state != 'draft'" groups="ecodoo_core.group_ecodoo_manager"/>
                        <button name="action_archive" string="Archive" type="object" class="btn-secondary" invisible="state != 'approved'" groups="ecodoo_core.group_ecodoo_manager"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" class="btn-secondary" invisible="state != 'archived'" groups="ecodoo_core.group_ecodoo_manager"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_approve" string="Approve" type="object" class="oe_stat_button" icon="fa-check" invisible="state != 'draft'" groups="ecodoo_core.group_ecodoo_manager"/>
                            <button name="action_archive" string="Archive" type="object" class="oe_stat_button" icon="fa-archive" invisible="state != 'approved'" groups="ecodoo_core.group_ecodoo_manager"/>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="activity_type"/>
                                <field name="input_uom_id" options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="kg_co2e_per_unit" widget="float" options="{'precision': 6}"/>
                                <field name="version"/>
                                <field name="source_url" widget="url"/>
                                <field name="company_id" options="{'no_create': True}"/>
                            </group>
                        </group>
                        <group>
                            <group string="Validity">
                                <field name="valid_from"/>
                                <field name="valid_to"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_ecodoo_emission_factor_tree" model="ir.ui.view">
            <field name="name">ecodoo.emission.factor.tree</field>
            <field name="model">ecodoo.emission.factor</field>
            <field name="arch" type="xml">
                <tree string="Emission Factors" decoration-muted="state == 'archived'" decoration-info="state == 'draft'" decoration-success="state == 'approved'">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="activity_type"/>
                    <field name="input_uom_id"/>
                    <field name="kg_co2e_per_unit" widget="float" options="{'precision': 6}"/>
                    <field name="version"/>
                    <field name="valid_from"/>
                    <field name="valid_to"/>
                    <field name="state"/>
                    <field name="company_id"/>
                </tree>
            </field>
        </record>

        <record id="view_ecodoo_emission_factor_search" model="ir.ui.view">
            <field name="name">ecodoo.emission.factor.search</field>
            <field name="model">ecodoo.emission.factor</field>
            <field name="arch" type="xml">
                <search string="Emission Factors">
                    <field name="name" string="Name"/>
                    <field name="code" string="Code"/>
                    <field name="activity_type" string="Activity Type"/>
                    <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="archived" string="Archived" domain="[('state', '=', 'archived')]"/>
                    <group string="Group By">
                        <filter name="by_activity_type" string="Activity Type" domain="[]" context="{'group_by': 'activity_type'}"/>
                        <filter name="by_state" string="State" domain="[]" context="{'group_by': 'state'}"/>
                        <filter name="by_company" string="Company" domain="[]" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_ecodoo_emission_factor" model="ir.actions.act_window">
            <field name="name">Emission Factors</field>
            <field name="res_model">ecodoo.emission.factor</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_ecodoo_emission_factor_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create your first emission factor</p>
                <p>Define emission factors with versioning and validity dates. Approved factors are immutable.</p>
            </field>
        </record>
    </data>
</odoo>