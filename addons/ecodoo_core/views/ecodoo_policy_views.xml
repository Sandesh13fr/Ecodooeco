<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Policy Acknowledgement Views -->
        <record id="view_ecodoo_policy_acknowledgement_form" model="ir.ui.view">
            <field name="name">ecodoo.policy.acknowledgement.form</field>
            <field name="model">ecodoo.policy.acknowledgement</field>
            <field name="arch" type="xml">
                <form string="Policy Acknowledgement">
                    <sheet>
                        <group>
                            <field name="policy_id" options="{'no_create': True}" domain="[('state', '=', 'published')]"/>
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="acknowledged_at" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_ecodoo_policy_acknowledgement_tree" model="ir.ui.view">
            <field name="name">ecodoo.policy.acknowledgement.tree</field>
            <field name="model">ecodoo.policy.acknowledgement</field>
            <field name="arch" type="xml">
                <list string="Policy Acknowledgements">
                    <field name="policy_id"/>
                    <field name="employee_id"/>
                    <field name="acknowledged_at"/>
                </list>
            </field>
        </record>

        <record id="view_ecodoo_policy_acknowledgement_search" model="ir.ui.view">
            <field name="name">ecodoo.policy.acknowledgement.search</field>
            <field name="model">ecodoo.policy.acknowledgement</field>
            <field name="arch" type="xml">
                <search string="Policy Acknowledgements">
                    <field name="policy_id" string="Policy"/>
                    <field name="employee_id" string="Employee"/>
                    <filter name="my_acknowledgements" string="My Acknowledgements" domain="[('employee_id.user_id', '=', uid)]"/>
                </search>
            </field>
        </record>

        <record id="action_ecodoo_policy_acknowledgement" model="ir.actions.act_window">
            <field name="name">Policy Acknowledgements</field>
            <field name="res_model">ecodoo.policy.acknowledgement</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_ecodoo_policy_acknowledgement_search"/>
        </record>

        <!-- Compliance Issue Views -->
        <record id="view_ecodoo_compliance_issue_form" model="ir.ui.view">
            <field name="name">ecodoo.compliance.issue.form</field>
            <field name="model">ecodoo.compliance.issue</field>
            <field name="arch" type="xml">
                <form string="Compliance Issue">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="open,in_progress,resolved"/>
                        <button name="action_in_progress" string="Start Work" type="object" class="btn-primary" invisible="state != 'open'" groups="ecodoo_core.group_ecodoo_manager"/>
                        <button name="action_resolve" string="Resolve" type="object" class="btn-primary" invisible="state != 'in_progress'" groups="ecodoo_core.group_ecodoo_manager"/>
                        <button name="action_reopen" string="Reopen" type="object" class="btn-secondary" invisible="state != 'resolved'" groups="ecodoo_core.group_ecodoo_manager"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_in_progress" string="In Progress" type="object" class="oe_stat_button" icon="fa-play" invisible="state != 'open'" groups="ecodoo_core.group_ecodoo_manager"/>
                            <button name="action_resolve" string="Resolve" type="object" class="oe_stat_button" icon="fa-check" invisible="state != 'in_progress'" groups="ecodoo_core.group_ecodoo_manager"/>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="severity" widget="priority"/>
                                <field name="owner_id" options="{'no_create': True}"/>
                                <field name="due_date"/>
                            </group>
                            <group>
                                <field name="state"/>
                                <field name="resolved_at" readonly="1"/>
                                <field name="company_id" options="{'no_create': True}"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description"/>
                        </group>
                        <group string="Resolution">
                            <field name="resolution"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_ecodoo_compliance_issue_tree" model="ir.ui.view">
            <field name="name">ecodoo.compliance.issue.tree</field>
            <field name="model">ecodoo.compliance.issue</field>
            <field name="arch" type="xml">
                <list string="Compliance Issues" decoration-danger="severity == 'critical'" decoration-warning="severity == 'high'" decoration-info="severity == 'medium'" decoration-muted="severity == 'low'">
                    <field name="name"/>
                    <field name="severity"/>
                    <field name="owner_id"/>
                    <field name="due_date"/>
                    <field name="state"/>
                    <field name="resolved_at"/>
                </list>
            </field>
        </record>

        <record id="view_ecodoo_compliance_issue_search" model="ir.ui.view">
            <field name="name">ecodoo.compliance.issue.search</field>
            <field name="model">ecodoo.compliance.issue</field>
            <field name="arch" type="xml">
                <search string="Compliance Issues">
                    <field name="name" string="Name"/>
                    <field name="description" string="Description"/>
                    <filter name="open" string="Open" domain="[('state', '=', 'open')]"/>
                    <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                    <filter name="resolved" string="Resolved" domain="[('state', '=', 'resolved')]"/>
                    <filter name="critical" string="Critical" domain="[('severity', '=', 'critical')]"/>
                    <filter name="high" string="High" domain="[('severity', '=', 'high')]"/>
                    <group>
                        <filter name="by_state" string="State" domain="[]" context="{'group_by': 'state'}"/>
                        <filter name="by_severity" string="Severity" domain="[]" context="{'group_by': 'severity'}"/>
                        <filter name="by_owner" string="Owner" domain="[]" context="{'group_by': 'owner_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_ecodoo_compliance_issue" model="ir.actions.act_window">
            <field name="name">Compliance Issues</field>
            <field name="res_model">ecodoo.compliance.issue</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_ecodoo_compliance_issue_search"/>
        </record>

    </data>
</odoo>
